#. Translators: the configuration submenu in NVDA Preferences menu
msgid "Weather Plus &Settings"
msgstr "Weather Plus 설정(&S)"

msgid "Show configuration items."
msgstr "구성 항목을 표시합니다."

#. Translators: item to open primary configuration window
msgid "Set and &manage your cities..."
msgstr "도시 설정 및 관리(&M)..."

msgid "Displays or allows to set the current cities from a list"
msgstr "목록에서 현재 도시 표시 또는 설정"

#. Translators: item to open window to set up a temporary city
msgid "Set a &temporary city..."
msgstr "임시 도시 설정(&T)..."

msgid "Allows to set one temporary city from a list"
msgstr "목록에서 임시 도시 하나 설정"

#. Translators: item to open the help file for the current language
msgid "&Documentation"
msgstr "문서(&D)"

msgid "Opens the help file for the current language"
msgstr "현재 언어 도움말 열기"

#. Translators: item to notify if there is an upgraded version available
msgid "&Check for Upgrade..."
msgstr "업데이트 확인(&C)..."

msgid "Notify if there is an upgraded version available"
msgstr "새 버전 알리기"

#. opens the Weather Plus settings window
#. Translators: the title of main settings window
msgid "Settings"
msgstr "설정"

msgid "Preset"
msgstr "프리셋"

msgid "None"
msgstr "없음"

#. Translators: the message in the main settings window
msgid "Enter a City or choose one from the list, if available."
msgstr "도시를 입력하거나, 가능한 경우 목록에서 하나를 선택하십시오."

#. Translators: dialog message in case of invalid city or with incomplete data
#. Translators: dialog message used to describe one of the 2 types of errors in city
msgid "The city"
msgstr "도시"

msgid "has not been preset."
msgstr "프리셋으로 저장되지 않았습니다."

msgid "Will be used in temporary mode!"
msgstr "임시 모드로 사용됩니다!"

#. Translators: the dialog title
#. offers to save the list changed
#. Translators: the dialog title
#. Translators: title dialog
#. Translators: the dialog title
msgid "Notice!"
msgstr "알림!"

#. Translators: dialog message to warn that the list has not been saved
msgid "You have modified the list of your cities"
msgstr "도시 목록 수정됨"

msgid "Do you want to save it?"
msgstr "저장하시겠습니까?"

msgid "The cities on your list are not compatible with the Weather API!"
msgstr "목록의 도시가 Weather API와 호환되지 않습니다!"

msgid ""
"They have to be tested and validated, you can do it from the addon settings "
"window."
msgstr "도시를 테스트하고 확인해야 합니다. 추가 기능 설정 창에서 할 수 있습니다."

#. Translators: the dialog title to  setting a temporary city
msgid "Setting up a temporary city"
msgstr "임시 도시 설정"

#. addss short cut keys
msgid "Cities List available:"
msgstr "사용 가능한 도시 목록:"

msgid "Documentation not available for the current language!"
msgstr "현재 언어로 된 문서가 없습니다!"

#. Translators: dialog message and title used when it was not possible to find data
msgid ""
"Sorry, I can not receive data, problems with the download page, try again "
"later please!"
msgstr "죄송합니다. 다운로드 페이지 문제로 데이터를 받을 수 없습니다. 나중에 다시 시도하십시오!"

#. Translators: dialog message and title used when it not possible to connect and receive data
msgid ""
"Sorry, I can not receive data, verify that your internet connection is "
"active, or try again later!"
msgstr "죄송합니다. 데이터를 받을 수 없습니다. 인터넷 연결이 활성 상태인지 확인하거나 나중에 다시 시도하십시오!"

msgid "version"
