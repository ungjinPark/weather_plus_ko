msgstr "API 응답 언어:"

#. check boxes
msgid ""
"&Copy the weather report and weather forecast, including city details to "
"clipboard"
msgstr "도시 세부 정보를 포함한 날씨 보고와 예보를 클립보드에 복사(&C)"

msgid "Enable &audio effects (only for the current weather conditions)"
msgstr "오디오 효과 사용(&A)(현재 날씨 상태에만 적용)"

msgid "Use only &weather effects"
msgstr "날씨 효과만 사용(&W)"

msgid "General audio volume"
msgstr "전체 오디오 볼륨"

msgid "Current audio volume"
msgstr "현재 오디오 볼륨"

#. check boxes
msgid "Enable &help buttons in the settings window"
msgstr "설정 창에 도움말 버튼 사용(&H)"

msgid "Read &wind information"
msgstr "바람 정보 읽기(&W)"

msgid "Add wind directi&on"
msgstr "풍향 추가(&O)"

msgid "Add wi&nd speed"
msgstr "풍속 추가(&N)"

msgid "Add speed in &meters per second of the wind"
msgstr "풍속을 미터/초로 추가(&M)"

msgid "Add wind &gust speed"
msgstr "돌풍 속도 추가(&G)"

msgid "Add perceived &temperature"
msgstr "체감 온도 추가(&T)"

msgid "&Read atmospherical information"
msgstr "대기 정보 읽기(&R)"

msgid "Add humidity va&lue"
msgstr "습도 값 추가(&L)"

msgid "Add &visibility value"
msgstr "가시거리 값 추가(&V)"

msgid "Add cloudiness &value"
msgstr "구름량 값 추가(&V)"

msgid "Add precipitation &value"
msgstr "강수량 값 추가(&V)"

msgid "Add &ultraviolet radiation value"
msgstr "자외선 지수 값 추가(&U)"

msgid "Add atmospheric &pressure value"
msgstr "기압 값 추가(&P)"

msgid "Indicates the atmospheric pressure in millimeters of mercur&y (mmHg)"
msgstr "기압을 수은주 밀리미터(mmHg)로 표시(&Y)"

msgid "Read a&stronomical information"
msgstr "천문 정보 읽기(&S)"

msgid "Enable reading of the hours in &24-hour format"
msgstr "24시간 형식으로 시간 읽기 사용(&2)"

msgid "Use the comma to separate decimals, example (4,&15)"
msgstr "소수점 구분에 쉼표 사용, 예: (4,&15)"

msgid "Check for &upgrade"
msgstr "업데이트 확인(&U)"

msgid "Test the city validity  and find the data of it."
msgstr "도시가 유효한지 테스트하고 데이터를 찾습니다."

msgid "Add the current city into your list."
msgstr "현재 도시를 목록에 추가합니다."

msgid "Displays information about the current city."
msgstr "현재 도시 정보를 표시합니다."

msgid "Allows you to define the area, in order to adapt the sound effects."
msgstr "효과음을 맞추기 위해 지역 유형을 정의할 수 있습니다."

msgid ""
"Presets the current city as the default, will be used every time you restart "
"the plugin."
msgstr "현재 도시를 기본값으로 프리셋합니다. 플러그인을 다시 시작할 때마다 사용됩니다."

msgid "Delete  the current city from your list."
msgstr "목록에서 현재 도시를 삭제합니다."

msgid "Rename the current city."
msgstr "현재 도시의 이름을 변경합니다."

msgid ""
"Permits to incorporate in your list new cities importing them from another "
"list with the extension *.zipcodes; you can select the city you want to "
"import, by turning on the check box associated."
msgstr "*.zipcodes 확장자를 가진 다른 목록에서 새 도시를 가져와 현재 목록에 포함할 수 있습니다. 해당 확인란을 선택하여 가져올 도시를 선택할 수 있습니다."

msgid "Permits to save your list of cities in a specified path."
msgstr "도시 목록을 지정한 경로에 저장할 수 있습니다."

msgid "You can enter or search for a city"
msgstr "도시 입력 또는 검색"

msgid "By Latitude and Longitude: 48.8567,2.3508"
msgstr "위도와 경도: 48.8567,2.3508"

msgid "By City name: Paris"
msgstr "도시 이름: Paris"

msgid "By City name and country: Toronto,Canada"
msgstr "도시 이름과 국가: Toronto,Canada"

msgid "Or Toronto,CA"
msgstr "또는 Toronto,CA"

msgid "By City name and region: Toronto,Ontario"
msgstr "도시 이름과 지역: Toronto,Ontario"

msgid "By US zip: 10001"
msgstr "미국 우편번호: 10001"

msgid "By UK postcode: SW1"
msgstr "영국 우편번호: SW1"

msgid "By Canada postal code: G2J"
msgstr "캐나다 우편번호: G2J"

msgid "By metar:<metar code>: metar:EGLL"
msgstr "METAR:<metar 코드>: metar:EGLL"

msgid "By iata:<3 digit airport code>: iata:DXB"
msgstr "IATA:<3자리 공항 코드>: iata:DXB"

msgid "By auto:ip IP lookup: auto:ip"
msgstr "auto:ip IP 조회: auto:ip"

msgid "By IP address (IPv4 and IPv6 supported): 100.0.0.1"
msgstr "IP 주소(IPv4 및 IPv6 지원): 100.0.0.1"

msgid "if there will be cities with the same name, will be listed"
msgstr "같은 이름의 도시가 있으면 목록에 표시됩니다"

msgid "By default, confirming a selection, is used the postal code"
msgstr "기본적으로 선택을 확인하면 우편번호가 사용됩니다"

msgid ""
"If the postal code is not valid, will be used a text string: city, state, "
"region"
msgstr "우편번호가 유효하지 않으면 도시, 주, 지역 텍스트 문자열이 사용됩니다"

msgid "You can indicate how to proceed by prefixing the following commands"
msgstr "다음 명령 접두사를 붙여 처리 방식을 지정할 수 있습니다"

msgid ""
"Direct (cities with the same name, will not listed), by typing D:City: D:"
"Paris"
msgstr "직접 검색(같은 이름의 도시는 나열하지 않음), D:도시 입력: D:Paris"

msgid "Geographic coordinates, by typing G:City: G:Venezia"
msgstr "지리 좌표, G:도시 입력: G:Venezia"

msgid "Text string, by typing T:City: T:Bologna"
msgstr "텍스트 문자열, T:도시 입력: T:Bologna"

msgid "If the city is not found"
msgstr "도시를 찾지 못한 경우"

msgid "Try to reverse the order in the search key"
msgstr "검색어 순서를 바꿔 보십시오"

msgid "Try with or without the country of origin"
msgstr "국가 이름을 넣거나 빼고 시도하십시오"

msgid "Try to merge the name with hyphens, or separate it with separator"
msgstr "이름을 하이픈으로 합치거나 구분자로 나누어 보십시오"

msgid "Try deleting apostrophes"
msgstr "아포스트로피를 삭제해 보십시오"

msgid "Try changing the vowels accented with normal vowels"
msgstr "악센트가 있는 모음을 일반 모음으로 바꿔 보십시오"

msgid "Try to change in English some parts"
msgstr "일부를 영어로 바꿔 보십시오"

msgid "Try with a closest location"
msgstr "가장 가까운 위치로 시도하십시오"

#. Translators: the title of the help window
msgid "Help placing"
msgstr "위치 도움말"

msgid "No sound effect in memory!"
msgstr "메모리에 효과음이 없습니다!"

msgid "I can't reproduce the sound."
msgstr "소리를 재생할 수 없습니다."

#. Translators: message dialog
msgid "Choose search key for"
msgstr "검색 키 선택"

#. Translators: the dialog message
msgid "Unfortunately I could not recover enough data to find the city."
msgstr "안타깝게도 도시를 찾을 만큼 충분한 데이터를 복구하지 못했습니다."

msgid "Do I try anyway?"
msgstr "그래도 시도할까요?"

msgid "not found! Press F1 for help on entering data."
